# Groq API key – get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model name (default: compound-beta)
GROQ_MODEL=compound-beta

# Unsplash API – get yours at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels API – get yours at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here